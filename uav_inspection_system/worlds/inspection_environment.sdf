      </link>
    </model>

    <model name="tree_4">
      <static>true</static>
      <pose>28 -18 0 0 0 0</pose>
      <link name="link">
        <collision name="trunk_collision"><pose>0 0 4 0 0 0</pose><geometry><cylinder><radius>1</radius><length>8</length></cylinder></geometry></collision>
        <collision name="crown_collision"><pose>0 0 10 0 0 0</pose><geometry><sphere><radius>3.2</radius></sphere></geometry></collision>
        <visual name="trunk_visual"><pose>0 0 4 0 0 0</pose><geometry><cylinder><radius>1</radius><length>8</length></cylinder></geometry><material><ambient>0.35 0.23 0.12 1</ambient><diffuse>0.42 0.28 0.15 1</diffuse></material></visual>
        <visual name="crown_visual"><pose>0 0 10 0 0 0</pose><geometry><sphere><radius>3.2</radius></sphere></geometry><material><ambient>0.05 0.45 0.08 1</ambient><diffuse>0.08 0.55 0.1 1</diffuse></material></visual>
