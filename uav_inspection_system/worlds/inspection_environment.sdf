    <model name="tree_3">
      <static>true</static>
      <pose>14 26 0 0 0 0</pose>
      <link name="link">
        <collision name="trunk_collision"><pose>0 0 3 0 0 0</pose><geometry><cylinder><radius>0.75</radius><length>6</length></cylinder></geometry></collision>
        <collision name="crown_collision"><pose>0 0 7.8 0 0 0</pose><geometry><sphere><radius>2.6</radius></sphere></geometry></collision>
        <visual name="trunk_visual"><pose>0 0 3 0 0 0</pose><geometry><cylinder><radius>0.75</radius><length>6</length></cylinder></geometry><material><ambient>0.35 0.23 0.12 1</ambient><diffuse>0.42 0.28 0.15 1</diffuse></material></visual>
